<Window x:Class="LeVinhTu_0577.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LeVinhTu_0577"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        mc:Ignorable="d"
        Title="Hệ thống quản lý sách" Height="650" Width="900">

    <DockPanel>
        <!-- Status bar -->
        <StatusBar DockPanel.Dock="Bottom">
            <TextBlock Text="Hệ thống quản lý sách" />
        </StatusBar>

        <TabControl DockPanel.Dock="Top">
            <TabItem Header="Sách">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <GroupBox Header="Thông tin sách" Grid.Row="0" Margin="0,0,0,8">
                        <Grid Margin="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Label Grid.Row="0" Grid.Column="0"
                                   Content="Mã sách" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBox x:Name="txt_MaSach"
                                     Grid.Row="0" Grid.Column="1"
                                     FontSize="16" Margin="0,0,16,4"/>

                            <!-- Tìm kiếm -->
                            <Label Grid.Row="0" Grid.Column="2"
                                   Content="Tìm Mã / Tên" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <StackPanel Grid.Row="0" Grid.Column="3"
                                        Orientation="Horizontal">
                                <TextBox x:Name="txt_Tim"
                                         Width="140" FontSize="14" Margin="0,0,4,0"/>
                                <Button Content="Tìm" FontSize="14" Width="60" Click="Tim"/>
                            </StackPanel>

                            <!-- Tên sách -->
                            <Label Grid.Row="1" Grid.Column="0"
                                   Content="Tên sách" VerticalAlignment="Center" Margin="0,4,8,0"/>
                            <TextBox x:Name="txt_TenSach"
                                     Grid.Row="1" Grid.Column="1"
                                     FontSize="16" Margin="0,4,16,4"/>
                            <Label Grid.Row="2" Grid.Column="0"
                                   Content="Thể loại" VerticalAlignment="Center" Margin="0,4,8,0"/>
                            <ComboBox x:Name="cb_TheLoai"
                                      Grid.Row="2" Grid.Column="1"
                                      FontSize="16" Margin="0,4,16,4"
                                      DisplayMemberPath="TenLoai"
                                      SelectedValuePath="MaLoai"
                                      DropDownClosed="cb_TheLoai_DropDownClosed"/>

                            <!-- Ngày xuất bản -->
                            <Label Grid.Row="2" Grid.Column="2"
                                   Content="Ngày xuất bản" VerticalAlignment="Center" Margin="0,4,8,0"/>
                            <DatePicker x:Name="date_NgayXB"
                                        Grid.Row="2" Grid.Column="3"
                                        FontSize="16" Margin="0,4,0,4"
                                        SelectedDate="{x:Static sys:DateTime.Now}"
                                        SelectedDateChanged="date_NgayXB_SelectedDateChanged"/>
                            <Label Grid.Row="1" Grid.Column="1"
                                   Content="Năm thứ" VerticalAlignment="Center" Margin="456.6,10.2,9.6,38.2" Grid.ColumnSpan="2" Grid.RowSpan="2"/>
                            <TextBox x:Name="txt_namThu"
                                     Grid.Row="1" Grid.Column="3"
                                     FontSize="16" Margin="0.4,7.2,148.4,37.2" Width="80" Grid.RowSpan="2"/>
                        </Grid>
                    </GroupBox>
                    <GroupBox Header="Chức năng" Grid.Row="1" Margin="0,0,0,8">
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center" Margin="0,4">
                            <Button Content="Thêm" Click="Them" FontSize="14"
                                    Margin="8" Width="90"/>
                            <Button Content="Xoá" Click="Xoa" FontSize="14"
                                    Margin="8" Width="90"/>
                            <Button Content="Sửa" Click="Sua" FontSize="14"
                                    Margin="8" Width="90"/>
                            <Button Content="Load lại" Click="LoadLai" FontSize="14"
                                    Margin="8" Width="100"/>
                            <TextBlock x:Name="txt_DemSach"
                   DockPanel.Dock="Right"
                   VerticalAlignment="Center"
                   Margin="20,0,10,0"
                   FontSize="14"
                   FontWeight="Bold"
                   Text="Tổng số sách: 0"/>

                        </StackPanel>
                    </GroupBox>
                    <GroupBox Header="Dữ liệu" Grid.Row="2">
                        <DataGrid x:Name="dg_Sach"
                                  Margin="4"
                                  FontSize="14"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  SelectionChanged="dg_Sach_SelectionChanged">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Mã sách" Binding="{Binding MaSach}" Width="*"/>
                                <DataGridTextColumn Header="Tên sách" Binding="{Binding TenSach}" Width="2*"/>
                                <DataGridTextColumn Header="Mã thể loại" Binding="{Binding MaLoai}" Width="*"/>
                                <DataGridTextColumn Header="Ngày xuất bản"
                                                    Binding="{Binding NgayXuatBan, StringFormat=dd/MM/yyyy}"
                                                    Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </GroupBox>
                </Grid>
            </TabItem>

            <TabItem Header="Hệ Thống">
                <Grid>
                    <TextBlock Text="Thông tin hệ thống / trợ giúp"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="18"/>
                </Grid>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
